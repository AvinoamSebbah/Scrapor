# Copy to /opt/agali-scrapor/kamatera.env on Kamatera and fill values.

AGALI_SCRAPOR_DIR=/opt/agali-scrapor
APP_DATA_PATH=/opt/agali-scrapor/app_data
KAMATERA_SUMMARY_FILE=/opt/agali-scrapor/run_summary.json
KAMATERA_LOG_DIR=/opt/agali-scrapor/logs

# Comma-separated stores handled specifically by Kamatera.
ENABLED_SCRAPERS=OSHER_AD
ENABLED_FILE_TYPES=
OPERATION=scraping,converting,api_update,clean_dump_files
OUTPUT_DESTINATION=postgres
LOG_LEVEL=WARNING
TZ=Asia/Jerusalem

# Database.
POSTGRESQL_URL=postgresql://USER:PASSWORD@HOST:5432/DB

# Telegram Bot 1 + Bot 2.
TELEGRAM_BOT1_TOKEN=
TELEGRAM_BOT1_CHAT_ID=
TELEGRAM_BOT2_TOKEN=
TELEGRAM_BOT2_CHAT_ID=
